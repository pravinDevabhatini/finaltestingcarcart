# ─── Server ───────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────
MONGO_URI=mongodb://localhost:27017/carcart
# Cloud: mongodb+srv://<user>:<pass>@cluster.mongodb.net/carcart

# ─── JWT ──────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── File Upload ──────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ─── Frontend URL (CORS) ──────────────────
FRONTEND_URL=http://localhost:5173

# ─── Timezone ─────────────────────────────
TZ=Asia/Kolkata
